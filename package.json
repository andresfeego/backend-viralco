{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "node scripts/build.mjs",
    "start": "node dist/server.js",
    "db:migrate": "knex migrate:latest --knexfile knexfile.cjs",
    "db:rollback": "knex migrate:rollback --knexfile knexfile.cjs",
    "db:seed": "knex seed:run --knexfile knexfile.cjs",
    "db:local:up": "docker compose -f docker-compose.mariadb.yml up -d",
    "db:local:down": "docker compose -f docker-compose.mariadb.yml down",
    "db:local:logs": "docker compose -f docker-compose.mariadb.yml logs -f mariadb",
    "db:local:migrate": "DB_HOST=127.0.0.1 DB_PORT=3307 DB_USER=viralco DB_PASSWORD=viralco_pass DB_NAME=viralco DB_CHARSET=utf8mb4 knex migrate:latest --knexfile knexfile.cjs",
    "db:local:reset": "docker compose -f docker-compose.mariadb.yml down -v && docker compose -f docker-compose.mariadb.yml up -d"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.826.0",
    "@aws-sdk/s3-request-presigner": "^3.826.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.44.2",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.1.0",
    "mysql2": "^3.12.0"
  },
  "devDependencies": {
    "esbuild": "^0.27.2",
    "tsx": "^4.19.4"
  }
}
